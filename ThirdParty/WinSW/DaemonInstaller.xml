<service>

    <!-- ID of the service. It should be unique across the Windows system-->
    <id>qtet-daemon</id>
    <!-- Display name of the service -->
    <name>QtEasyTier Daemon Service (powered by WinSW)</name>
    <!-- Service description -->
    <description>QtEasyTier Daemon</description>

    <!-- Path to the executable, which should be started -->
    <executable>%BASE%\qtet-daemon.exe</executable>

</service>