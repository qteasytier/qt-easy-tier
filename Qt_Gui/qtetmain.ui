     <property name="styleSheet">
      <string notr="true">/* 按钮基础样式：默认全透明、无边框、无焦点（无任何选中效果） */
QPushButton {
    width: 20px;
    height: 50px;
    border-radius: 8px;
    background-color: transparent;  /* 全透明背景 */
    color: #000000;
    font-size: 24px;
    text-align: center;
    border: none;               /* 【核心】默认无边框 */
    padding: 0;
    outline: none;              /* 【核心】禁用系统自动焦点框 */
}

/* 1. 鼠标悬停：显示基础边框（最浅） */
QPushButton:hover {
    border: 2px solid #66ccff;
}

/* 3. 鼠标按下：显示最深边框（颜色最深，符合要求）+ 文字位移 */
QPushButton:pressed {
    border: 2px solid #3399dd;  /* 【核心】按下时边框颜色最深 */
    padding-left: 2px;
    padding-top: 2px;
}

/* 禁用状态：无边框、半透明效果 */
QPushButton:disabled {
    background-color: rgba(179, 217, 255, 0.3);
    color: #e6e6e6;
    border: none;
}</string>
