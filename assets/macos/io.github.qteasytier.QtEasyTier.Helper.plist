<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>io.github.qteasytier.QtEasyTier.Helper</string>
    <key>BundleProgram</key>
    <string>Contents/MacOS/QtEasyTierHelper</string>
    <key>ProgramArguments</key>
    <array>
        <string>QtEasyTierHelper</string>
        <string>--daemon</string>
        <string>--xpc-service</string>
        <string>io.github.qteasytier.QtEasyTier.Helper</string>
    </array>
    <key>MachServices</key>
    <dict>
        <key>io.github.qteasytier.QtEasyTier.Helper</key>
        <true/>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>StandardOutPath</key>
    <string>/var/log/qteasytier-helper.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/qteasytier-helper.log</string>
</dict>
</plist>
