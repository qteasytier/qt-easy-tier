         <property name="styleSheet">
          <string notr="true">QPushButton {
    /* 基础样式：固定尺寸+圆角+背景色+字体 */
    width: 225px;               /* 固定宽度 */
    height: 40px;               /* 固定高度 */
    border-radius: 8px;         /* 圆角8px */
    background-color: #66ccff;  /* 主背景色 */
    color: #000000;             /* 文字白色（增强对比度） */
    font-size: 24px;            /* 字体大小16 */
    text-align: center;         /* 文字居中 */
    border: none;               /* 移除默认边框 */
    padding: 0;                 /* 清除默认内边距，避免尺寸偏差 */
    /* 禁用默认焦点框（可选，提升美观度） */
    outline: none;
}

QPushButton:hover {
    /* 悬停效果：轻微加深背景色，提升交互感 */
    background-color: #5bc0f8;
}

QPushButton:pressed {
    /* 点击效果：颜色加深+文字轻微位移+背景进一步加深 */
    background-color: #4bb3ee;  /* 比悬停更深的蓝色 */
    padding-left: 2px;          /* 文字右移2px（视觉上的按下位移） */
    padding-top: 2px;           /* 文字下移2px */
}

/* 可选：禁用状态样式（增强鲁棒性） */
QPushButton:disabled {
    background-color: #b3d9ff;
    color: #e6e6e6;
}</string>
