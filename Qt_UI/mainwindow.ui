         <property name="styleSheet">
          <string notr="true">QListWidget {
    border-radius: 8px;
    border: 1px solid #ccc;     /* 设置边框，这样圆角更明显 */
    padding: 3px;               /* 内边距，让内容不要紧贴边框 */
}

QListWidget::item {
    height: 36px;  /* 这里的60px是你想要的默认高度，可自行修改 */
    font-size: 14px;
}</string>
